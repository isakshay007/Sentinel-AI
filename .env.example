# SentinelAI — Environment Variables
# Copy to .env and fill in values. Never commit .env to version control.

# =============================================================================
# REQUIRED
# =============================================================================

# Groq API key for LLM (Watcher, Diagnostician, Strategist, Executor)
GROQ_API_KEY=your_groq_api_key_here

# Database (PostgreSQL). Default matches alembic.ini for local dev.
DATABASE_URL=postgresql://sentinel:sentinel@localhost:5432/sentinelai

# =============================================================================
# FRONTEND (Next.js)
# =============================================================================

# Backend API base URL (set per environment)
# Development: http://localhost:8000 (backend runs on port 8000)
# Production: https://api.yourdomain.com
NEXT_PUBLIC_API_URL=http://localhost:8000

# =============================================================================
# OPTIONAL — Backend
# =============================================================================

# CORS origins (comma-separated). Use * for dev, explicit origins for production.
# Example: https://app.yourdomain.com,https://staging.yourdomain.com
CORS_ORIGINS=*

# Live observability backends
PROMETHEUS_URL=http://prometheus:9090
LOKI_URL=http://loki:3100

# Watcher loop configuration
WATCHER_ENABLED=1
WATCHER_POLL_INTERVAL=30

# =============================================================================
# OPTIONAL — ChromaDB / RAG
# =============================================================================

# ChromaDB persist directory (if used)
# CHROMA_PERSIST_DIR=data/chromadb
